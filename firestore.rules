rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net: default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmployee(userId) {
      return isSignedIn() && request.auth.token.email != null &&
        exists(/databases/$(database)/documents/usuarios/$(userId)/employees/$(request.auth.token.email.lower()));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    // Entity validations
    function isValidUser(user) {
      return user.keys().hasAll(['name', 'storeName', 'category', 'registered', 'email'])
        && user.name is string && user.name.size() <= 100
        && user.storeName is string && user.storeName.size() <= 100
        && user.category is string && user.category.size() <= 100
        && user.registered is bool
        && user.email is string && user.email.size() <= 200
        && (!user.keys().hasAny(['phoneNumber']) || user.phoneNumber == null || (user.phoneNumber is string && user.phoneNumber.size() <= 50))
        && (!user.keys().hasAny(['photoUrl']) || user.photoUrl == null || (user.photoUrl is string && user.photoUrl.size() <= 1000000))
        && (!user.keys().hasAny(['darkModeEnabled']) || user.darkModeEnabled == null || user.darkModeEnabled is bool);
    }

    function isValidSale(sale) {
      return sale.keys().hasAll(['date', 'time', 'amount', 'itemDescription', 'quantity'])
        && sale.date is string && sale.date.size() == 10
        && sale.time is string && sale.time.size() == 5
        && sale.amount is number && sale.amount >= 0
        && sale.itemDescription is string && sale.itemDescription.size() <= 200
        && sale.quantity is number;
    }

    function isValidInventoryItem(item) {
      return item.keys().hasAll(['name', 'quantity', 'minQuantity', 'price', 'category'])
        && item.name is string && item.name.size() <= 200
        && item.quantity is number
        && item.minQuantity is number && item.minQuantity >= 0
        && item.price is number && item.price >= 0
        && item.category is string && item.category.size() <= 100
        && (!item.keys().hasAny(['imageUrl']) || item.imageUrl == null || (item.imageUrl is string && item.imageUrl.size() <= 1000000))
        && (!item.keys().hasAny(['costPrice']) || item.costPrice == null || item.costPrice is number)
        && (!item.keys().hasAny(['profitMargin']) || item.profitMargin == null || item.profitMargin is number);
    }

    function isValidClient(client) {
      return client.keys().hasAll(['name', 'cellphone'])
        && client.name is string && client.name.size() <= 200
        && client.cellphone is string && client.cellphone.size() <= 50
        && (!client.keys().hasAny(['lastPurchaseDate']) || client.lastPurchaseDate == null || (client.lastPurchaseDate is string && client.lastPurchaseDate.size() <= 30))
        && (!client.keys().hasAny(['lastPurchaseTime']) || client.lastPurchaseTime == null || (client.lastPurchaseTime is string && client.lastPurchaseTime.size() <= 10))
        && (!client.keys().hasAny(['lastPurchaseTimestamp']) || client.lastPurchaseTimestamp == null || client.lastPurchaseTimestamp is number)
        && (!client.keys().hasAny(['lastPurchaseAmount']) || client.lastPurchaseAmount == null || client.lastPurchaseAmount is number);
    }

    function isValidGoal(goal) {
      return goal.keys().hasAll(['targetAmount', 'period'])
        && goal.targetAmount is number && goal.targetAmount >= 0
        && goal.period is string && goal.period.size() <= 50;
    }

    function isValidProgress(prog) {
      return prog.keys().hasAll(['storeNiche', 'currentTaskIndex', 'engagement', 'linkClicks', 'followers'])
        && prog.storeNiche is string && prog.storeNiche.size() <= 100
        && prog.currentTaskIndex is number && prog.currentTaskIndex >= 0 && prog.currentTaskIndex <= 10
        && prog.engagement is number
        && prog.linkClicks is number
        && prog.followers is number;
    }

    function isValidFeedback(feed) {
      return feed.keys().hasAll(['taskId', 'title', 'feedback'])
        && feed.taskId is number && feed.taskId >= 0
        && feed.title is string && feed.title.size() <= 200
        && feed.feedback is string && feed.feedback.size() <= 10000;
    }

    // Rules matching path hierarchies
    match /usuarios/{userId} {
      allow get: if isOwner(userId) || isEmployee(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if false;

      // Employees list subcollection
      match /employees/{employeeEmail} {
        allow get: if isOwner(userId) || (isSignedIn() && request.auth.token.email.lower() == employeeEmail.lower());
        allow list, create, update, delete: if isOwner(userId);
      }

      // Sales subcollection
      match /sales/{saleId} {
        allow get, list, create, update, delete: if isOwner(userId) || isEmployee(userId);
      }

      // Inventory Catalog subcollection
      match /inventory/{itemId} {
        allow get, list, create, update, delete: if isOwner(userId) || isEmployee(userId);
      }

      // Goals subcollection
      match /goals/{goalId} {
        allow get, list, create, update, delete: if isOwner(userId) || isEmployee(userId);
      }

      // Instagram progress document (single doc path)
      match /instagram/progress {
        allow get, create, update, delete: if isOwner(userId) || isEmployee(userId);
      }

      // Instagram feedbacks subcollection
      match /instagramFeedbacks/{feedbackId} {
        allow get, list, create, update, delete: if isOwner(userId) || isEmployee(userId);
      }

      // Clients subcollection
      match /clients/{clientId} {
        allow get, list, create, update, delete: if isOwner(userId) || isEmployee(userId);
      }
    }

    // Email to UID mapping rules for unified data access across auth methods
    match /email_to_uid/{safeEmail} {
      allow get: if true;
      allow create, update: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }
  }
}
